digraph G {
    subgraph cluster_original {
        label="original (cyclic set)";
        A1 [label="A"];
        B1 [label="B"];
        C1 [label="C"];
        D1 [label="D"];
        E1 [label="E"];
        F1 [label="F"];
        G1 [label="G"];
        H1 [label="H"];
        I1 [label="I"];
        J1 [label="J"];
        K1 [label="K"];
        L1 [label="L"];
        A1 -> B1 -> C1 -> D1 -> E1 -> F1 -> G1 -> C1 -> H1
            -> I1 -> J1 -> K1 -> L1;
    }
    subgraph cluster_split {
        label="split (acyclic subsets)";
        subgraph cluster_head_to_C {
            label="head to C";
            A -> B -> C;
        }
        subgraph cluster_loop_at_C {
            label="loop at C";
            D -> E -> F -> G;
        }
        subgraph cluster_tail_from_C {
            label="tail from C";
            H -> I -> J -> K -> L;
        }
    }
}
